# Configurações do Servidor
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Banco de Dados PostgreSQL
DATABASE_URL=postgresql://olimpiadas_user:senha123@localhost:5432/olimpiadas_db
DATABASE_TEST_URL=postgresql://olimpiadas_user:senha123@localhost:5432/olimpiadas_test

# Secrets (ALTERE EM PRODUÇÃO!)
SECRET_KEY=sua-chave-super-secreta-de-256-bits-aqui-mude-em-producao
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
CORS_METHODS=["GET", "POST", "PUT", "PATCH", "DELETE"]
CORS_HEADERS=["*"]

# Upload de Arquivos
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_IMAGE_EXTENSIONS=["jpg", "jpeg", "png", "svg"]
UPLOAD_PATH=./uploads
STATIC_PATH=./static

# Redis (Cache)
REDIS_URL=redis://localhost:6379/0

# Email (Opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu.email@gmail.com
SMTP_PASSWORD=sua-senha-app
EMAIL_FROM=olimpiadas@exemplo.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Sentry (Produção)
SENTRY_DSN=